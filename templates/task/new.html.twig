{% extends 'base.html.twig' %}
{% block title %}Créer une tâche
{% endblock %}
{% block body %}
	<div class="min-h-screen flex items-center justify-center bg-gray-50 p-4">
		<div
			class="w-lg bg-white rounded-2xl shadow-lg p-8 relative">

			{# close #}
			<a href="{{ path('app_dashboard') }}" class="absolute top-4 right-4 text-gray-400 hover:text-gray-600 text-xl">
				×
			</a>

			{# Titre #}
			<h1 class="text-xl font-bold text-gray-900">Créer une tâche</h1>
			<p class="text-sm text-gray-500 mb-6">Ajoutez une nouvelle tâche à votre liste</p>

			{# Form #}
			{{ form_start(form, {'attr': {'class': 'space-y-4'}}) }}

			{# Champ Titre #}
			<div>
				{{ form_label(form.title, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
				{{ form_widget(form.title, {'attr': {'class': 'w-full px-3 py-2 bg-gray-100 border border-gray-200 rounded-lg text-sm text-gray-700 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-gray-300'}}) }}
				{{ form_errors(form.title) }}
			</div>

			{# Champ Priorité #}
			<div>
				{{ form_label(form.priority, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
				{{ form_widget(form.priority, {'attr': {'class': 'w-full px-3 py-2 bg-gray-100 border border-gray-200 rounded-lg text-sm text-gray-500 focus:outline-none focus:ring-2 focus:ring-gray-300 appearance-none'}}) }}
				{{ form_errors(form.priority) }}
			</div>

			{# Champ Dossier #}
			<div>
				{{ form_label(form.Folder, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
				{{ form_widget(form.Folder, {'attr': {'class': 'w-full px-3 py-2 bg-gray-100 border border-gray-200 rounded-lg text-sm text-gray-500 focus:outline-none focus:ring-2 focus:ring-gray-300 appearance-none'}}) }}
				{{ form_errors(form.Folder) }}
			</div>

			{# Boutons en bas #}
			<div class="flex justify-end gap-2 pt-4">
				<a href="{{ path('app_dashboard') }}" class="px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-200 rounded-lg hover:bg-gray-50">
					Annuler
				</a>
				<button type="submit" class="px-4 py-2 text-sm font-medium text-white bg-gray-900 rounded-lg hover:bg-gray-800">
					Créer
				</button>
			</div>
			{{ form_end(form) }}
		</div>
	</div>
{% endblock %}
