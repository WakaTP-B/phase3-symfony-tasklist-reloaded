{% extends 'base.html.twig' %}
{% block title %}TaskList Reloaded
{% endblock %}

{% block body %}

	{# Main container #}
	<div
		class="flex h-screen">

		{# Left Sidebar #}
		<div class="w-64 bg-gray-900 text-white shrink-0">
			left
		</div>

		{# Right container #}
		<div
			class="flex flex-col flex-1 overflow-hidden">

			{# Navbar #}
			<nav class="flex items-center justify-between px-6 py-3 border-b border-gray-200 bg-white shrink-0">
				<div>
					<h1 class="text-xl font-bold text-gray-800">Gestion de Tâches</h1>
					<span class="text-sm text-gray-500">Organisez votre journée efficacement</span>
				</div>
				<div
					class="flex items-center gap-2">

					{# Gérer les priorités #}
					<a href="" class="flex items-center gap-2 px-4 py-2 text-sm text-gray-700 border border-gray-300 rounded-lg hover:bg-gray-50">
						<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewbox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="16" height="16">
							<path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.325.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 0 1 1.37.49l1.296 2.247a1.125 1.125 0 0 1-.26 1.431l-1.003.827c-.293.241-.438.613-.43.992a7.723 7.723 0 0 1 0 .255c-.008.378.137.75.43.991l1.004.827c.424.35.534.955.26 1.43l-1.298 2.247a1.125 1.125 0 0 1-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.47 6.47 0 0 1-.22.128c-.331.183-.581.495-.644.869l-.213 1.281c-.09.543-.56.94-1.11.94h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 0 1-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 0 1-1.369-.49l-1.297-2.247a1.125 1.125 0 0 1 .26-1.431l1.004-.827c.292-.24.437-.613.43-.991a6.932 6.932 0 0 1 0-.255c.007-.38-.138-.751-.43-.992l-1.004-.827a1.125 1.125 0 0 1-.26-1.43l1.297-2.247a1.125 1.125 0 0 1 1.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.086.22-.128.332-.183.582-.495.644-.869l.214-1.28Z"/>
							<path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/>
						</svg>
						Gérer les priorités
					</a>

					{# New Folder #}
					<a href="" class="flex items-center gap-2 px-4 py-2 text-sm text-gray-700 border border-gray-300 rounded-lg hover:bg-gray-50">
						<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewbox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="16" height="16">
							<path stroke-linecap="round" stroke-linejoin="round" d="M12 10.5v6m3-3H9m4.06-7.19-2.12-2.12a1.5 1.5 0 0 0-1.061-.44H4.5A2.25 2.25 0 0 0 2.25 6v12a2.25 2.25 0 0 0 2.25 2.25h15A2.25 2.25 0 0 0 21.75 18V9a2.25 2.25 0 0 0-2.25-2.25h-5.379a1.5 1.5 0 0 1-1.06-.44Z"/>
						</svg>
						Nouveau dossier
					</a>

					{# New Task #}
					<a href="{{ path('app_task_new') }}" class="flex items-center gap-2 px-4 py-2 text-sm text-white bg-gray-900 rounded-lg hover:bg-gray-700">
						<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewbox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="16" height="16">
							<path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/>
						</svg>
						Nouvelle tâche
					</a>

					{# Logout #}
					<a href="{{ path('app_logout') }}" class="flex items-center gap-2 px-4 py-2 text-sm text-gray-700 border border-gray-300 rounded-lg hover:bg-gray-50">
						<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewbox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="16" height="16">
							<path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0 0 13.5 3h-6a2.25 2.25 0 0 0-2.25 2.25v13.5A2.25 2.25 0 0 0 7.5 21h6a2.25 2.25 0 0 0 2.25-2.25V15M12 9l-3 3m0 0 3 3m-3-3h12.75"/>
						</svg>
						Déconnexion
					</a>

				</div>
			</nav>

			{# Filter #}
			<div class="px-6 py-3 border-b border-gray-200 bg-white shrink-0">
				Filtre
			</div>

			{# Task List #}
			<div class="flex-1 overflow-y-auto bg-gray-50 p-6">

				{% if tasks is empty %}
					<p class="text-gray-500">Aucune tâche pour le moment.</p>

				{% else %}
					<ul class="space-y-3">
						{% for task in tasks %}
							<li
								class="bg-white border border-gray-200 rounded-lg px-4 py-3 flex items-center justify-between hover:shadow-sm transition">

								{# Infos #}
								<div class="flex items-center gap-3 flex-1">
									<form method="post" action="{{ path('app_task_status', {id: task.id}) }}">
										<button type="submit" class="p-0 border-0 bg-transparent cursor-pointer leading-none">
											<input type="checkbox" class="w-4 h-4 rounded border-gray-300 pointer-events-none" {{ task.status != constant('App\\Enum\\TaskStatus::PENDING') ? 'checked' : '' }}>
										</button>
									</form>
									<div class="flex-1">
										<div class="flex items-center gap-2">
											<span class="font-medium {{ task.status == constant('App\\Enum\\TaskStatus::PENDING') ? 'text-gray-900' : 'line-through text-gray-400' }}">
												{{ task.title }}
											</span>
											{# Priority #}
											<span class="text-xs px-2 py-0.5 rounded-full font-medium" style="background-color: {{ task.priority.color }}; color: #1f2937;">
												{{ task.priority.name }}
											</span>
										</div>
										<div class="text-sm text-gray-500 mt-0.5">
											{{ task.status.value }}
										</div>
									</div>
								</div>

								{# Pin #}
								{# Pin #}
								<form method="post" action="{{ path('app_task_pin', {id: task.id}) }}">
									<button type="submit" class="text-gray-400 hover:text-gray-700">
										{% if task.isPinned %}
											{# Pin #}
											<svg xmlns="http://www.w3.org/2000/svg" viewbox="0 0 24 24" fill="currentColor" width="18" height="18">
												<path d="M16 9V4l1-1V2H7v1l1 1v5L6 11v2h5.2v7l.8 1 .8-1v-7H18v-2l-2-2z"/>
											</svg>
										{% else %}
											{# Not Pinned #}
											<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewbox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="18" height="18">
												<path stroke-linecap="round" stroke-linejoin="round" d="M16 12V4h1V2H7v2h1v8l-2 2v2h5.2v6h1.6v-6H18v-2l-2-2Z"/>
											</svg>
										{% endif %}
									</button>
								</form>

							</li>
						{% endfor %}
					</ul>
				{% endif %}
			</div>

		</div>
	</div>

{% endblock %}
