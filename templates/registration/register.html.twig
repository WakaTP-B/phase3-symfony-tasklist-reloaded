{% extends 'base.html.twig' %}
{% block title %}
    Inscription
{% endblock %}
{% block body %}
    <div class="min-h-screen bg-indigo-100 flex items-center justify-center">
        <div class="bg-white rounded-2xl shadow-md p-8 w-full max-w-sm">
            <h1 class="text-xl font-bold mb-1">Gestion de Tâches</h1>
            <p class="text-sm text-gray-400 mb-5">Organisez votre journée efficacement</p>
            <div class="flex bg-gray-100 rounded-lg p-1 mb-6">
                <a href="{{ path('app_login') }}"
                    class="flex-1 text-center py-2 text-sm rounded-md text-gray-500 hover:text-gray-700">
                    Connexion
                </a>
                <span class="flex-1 text-center py-2 text-sm rounded-md bg-white font-semibold shadow-sm">
                    Inscription
                </span>
            </div>
            {{ form_errors(registrationForm) }}
            {{ form_start(registrationForm, { attr: { class: 'flex flex-col space-y-4' } }) }}
                {{ form_row(registrationForm.email, {
                    label: 'Email',
                    label_attr: { class: 'block text-sm font-medium mb-1' },
                    attr: { 
                        placeholder: 'votre@email.com',
                        class: 'w-full bg-gray-100 rounded-lg px-4 py-3 text-sm outline-none'
                    }
                }) }}
                {{ form_row(registrationForm.username, {
                    label: "Nom d'utilisateur",
                    label_attr: { class: 'block text-sm font-medium mb-1' },
                    attr: {
                        placeholder: 'nom_utilisateur',
                        class: 'w-full bg-gray-100 rounded-lg px-4 py-3 text-sm outline-none'
                    }
                }) }}
                {{ form_row(registrationForm.plainPassword, {
                    label: 'Mot de passe',
                    label_attr: { class: 'block text-sm font-medium mb-1' },
                    attr: {
                        placeholder: '••••••••',
                        class: 'w-full bg-gray-100 rounded-lg px-4 py-3 text-sm outline-none'
                    }
                }) }}
                <button type="submit"
                    class="w-full bg-black text-white py-3 rounded-lg text-sm font-medium hover:bg-gray-800 transition">
                    S'inscrire
                </button>
            {{ form_end(registrationForm) }}
        </div>
    </div>
{% endblock %}